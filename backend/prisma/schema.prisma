generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts            Post[]
  aiConversations  AiConversation[]

  @@map("users")
}

model Post {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  excerpt        String?
  body           String
  featuredImage  String?
  status         String   @default("DRAFT")
  publishedAt    DateTime?
  readingTime    Int      @default(0)
  metaTitle      String?
  metaDescription String?
  ogImage        String?
  previewToken   String?
  scheduledAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  authorId   String
  author     User      @relation(fields: [authorId], references: [id])
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
  tags       Tag[]
  aiDraftOutputs AiDraftOutput[]
  comments       Comment[]
  reactions      PostReaction[]

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([status, scheduledAt])
  @@map("posts")
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  posts       Post[]

  @@map("categories")
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  @@map("tags")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  techStack   String[]
  thumbnail   String?
  liveUrl     String?
  githubUrl   String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
  @@map("page_views")
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model Experience {
  id          String   @id @default(uuid())
  role        String
  period      String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("experiences")
}

model AiConversation {
  id        String   @id @default(uuid())
  title     String
  topic     String
  status    String   @default("active")
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]
  brief    AiContentBrief?
  draft    AiDraftOutput?
  research AiResearchRun?
  rewriteProposals AiRewriteProposal[]
  usageEvents AiUsageEvent[]

  @@index([userId, status])
  @@index([userId, archivedAt, updatedAt])
  @@index([updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id           String   @id @default(uuid())
  role         String
  content      String
  metadataJson String?
  createdAt    DateTime @default(now())

  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

model AiContentBrief {
  id                    String   @id @default(uuid())
  topic                 String
  audience              String?
  goal                  String?
  tone                  String?
  primaryKeyword        String?
  secondaryKeywordsJson String?
  wordCount             Int?
  contentType           String?
  cta                   String?
  notes                 String?
  approvedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  conversationId String         @unique
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_content_briefs")
}

model AiDraftOutput {
  id                  String   @id @default(uuid())
  title               String
  slug                String
  excerpt             String?
  metaTitle           String?
  metaDescription     String?
  contentHtml         String
  categorySuggestion  String?
  tagsJson            String?
  outlineJson         String?
  faqJson             String?
  ogImagePrompt       String?
  seoScore            Int?
  engagementScore     Int?
  readabilityScore    Int?
  recommendationsJson String?
  verificationNotesJson String?
  verificationFlagsJson String?
  engagementInsightsJson String?
  internalLinkSuggestionsJson String?
  researchUsed        Boolean  @default(false)
  referencesEnabled   Boolean  @default(false)
  status              String   @default("generated")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  conversationId String         @unique
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  postId         String?
  post           Post?          @relation(fields: [postId], references: [id], onDelete: SetNull)
  rewriteProposals AiRewriteProposal[]

  @@index([postId])
  @@map("ai_draft_outputs")
}

model AiResearchRun {
  id                           String   @id @default(uuid())
  provider                     String
  status                       String   @default("completed")
  topicSummary                 String?
  searchIntent                 String?
  keywordIdeasJson             String?
  relatedQuestionsJson         String?
  competitorNotesJson          String?
  contentGapsJson              String?
  sourceNotesJson              String?
  internalLinkOpportunitiesJson String?
  riskFlagsJson                String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  conversationId String         @unique
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_research_runs")
}

model AiRewriteProposal {
  id            String   @id @default(uuid())
  action        String
  label         String
  summary       String?
  targetSection String
  originalText  String
  proposedText  String
  draftPatchJson String
  status        String   @default("proposed")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  draftOutputId  String
  draftOutput    AiDraftOutput  @relation(fields: [draftOutputId], references: [id], onDelete: Cascade)

  @@index([conversationId, status])
  @@index([draftOutputId])
  @@map("ai_rewrite_proposals")
}

model AiUsageEvent {
  id               String   @id @default(uuid())
  operation        String
  provider         String
  model            String?
  latencyMs        Int?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  success          Boolean  @default(true)
  errorMessage     String?
  metadataJson     String?
  createdAt        DateTime @default(now())

  conversationId String?
  conversation   AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([provider, operation, createdAt])
  @@map("ai_usage_events")
}

model ScriptSnippet {
  id        String   @id @default(uuid())
  name      String
  location  String   @default("head")
  code      String
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("script_snippets")
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
  @@map("rate_limit_buckets")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
  @@map("contact_messages")
}

model Comment {
  id        String   @id @default(uuid())
  author    String
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@map("comments")
}

model PostReaction {
  id        String   @id @default(uuid())
  emoji     String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  fingerprint String
  createdAt DateTime @default(now())

  @@unique([postId, fingerprint, emoji])
  @@index([postId])
  @@map("post_reactions")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, createdAt])
  @@map("newsletter_subscribers")
}

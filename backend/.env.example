DATABASE_URL=postgresql://myplweb:myplweb_secret@localhost:5432/myplweb
JWT_SECRET=replace-with-a-long-random-secret
PORT=3001
FRONTEND_URL=http://localhost:3200
FRONTEND_INTERNAL_URL=http://localhost:3200
REVALIDATE_SECRET=replace-with-a-shared-revalidation-secret
# Optional: only required if you want to enable one-time setup.
INSTALL_SECRET=replace-with-a-separate-install-secret

AI_PROVIDER=openai-compatible
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.4
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=6000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20
AI_ALERT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional alert destinations remain disabled until the admin enables them from Admin > Analytics.
AI_ALERT_MIN_LEVEL=warning
AI_ALERT_COOLDOWN_MS=300000
AI_ALERT_FAILURE_THRESHOLD=3
AI_ALERT_HIGH_LATENCY_MS=15000
AI_ALERT_LATENCY_THRESHOLD=3
AI_ALERT_LOOKBACK_MS=900000
AI_ALERT_COST_LOOKBACK_MS=3600000
AI_ALERT_COST_SPIKE_MULTIPLIER=1.5
AI_ALERT_COST_SPIKE_MIN_USD=1
AI_ALERT_COST_SPIKE_MIN_DELTA_USD=0.5
# Optional: force memory rate limiting. By default the backend uses the database store when DATABASE_URL is available.
# RATE_LIMIT_STORE=memory

# Supported research providers: disabled, exa, mock
RESEARCH_PROVIDER=disabled
RESEARCH_API_KEY=

# Optional manual live verification:
# RESEARCH_PROVIDER=exa
# RESEARCH_API_KEY=
# Then run: npm run verify:research

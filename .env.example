# ──────────────────────────────────────────────
# SimpleAIFolio — Environment Configuration Template
# Copy to .env and customize for your deployment
# ──────────────────────────────────────────────

# Database
DB_PASSWORD=change-this-to-a-secure-password

# Security — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret
REVALIDATE_SECRET=change-this-to-a-random-secret

# Admin Account (created on first startup)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-password
SEED_ADMIN_NAME=Admin

# URLs (update for your domain in production)
NEXT_PUBLIC_API_URL=http://localhost:3201
NEXT_PUBLIC_SITE_URL=http://localhost:3200
FRONTEND_URL=http://localhost:3200

# AI Writer (optional — leave disabled to start)
# Configure from Admin > Settings > AI Configuration
# AI_PROVIDER=openai-compatible
# AI_API_KEY=your-openai-compatible-key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# MCP Server (auto-deployed with Docker)
# API key is auto-generated — view it in Admin > Settings > MCP Server

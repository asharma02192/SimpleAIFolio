# Backend API URL (use localhost for local, internal Docker URL for containerized)
MCP_API_URL=http://localhost:3201

# Admin credentials for auto-login
MCP_AUTH_EMAIL=admin@example.com
MCP_AUTH_PASSWORD=change-this-password

# OR pre-generated JWT token (takes priority over email/password)
# MCP_API_TOKEN=

# ── HTTP Transport (for remote access) ──
# Set MCP_HTTP=true or run with --http flag to enable HTTP transport
# MCP_HTTP=true
# MCP_HTTP_PORT=3100

# API key to protect remote HTTP endpoint (leave empty for no auth)
# MCP_REMOTE_API_KEY=
